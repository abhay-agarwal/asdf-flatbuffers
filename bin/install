#!/usr/bin/env bash
set -euo pipefail

[ -n "${ASDF_INSTALL_VERSION:-}" ] || { echo "ASDF_INSTALL_VERSION not set"; exit 1; }
[ -n "${ASDF_INSTALL_PATH:-}" ]    || { echo "ASDF_INSTALL_PATH not set"; exit 1; }
[ -n "${ASDF_DOWNLOAD_PATH:-}" ]   || { echo "ASDF_DOWNLOAD_PATH not set"; exit 1; }

# Verify build prerequisites (README: needs cmake + a C++11 compiler).
command -v cmake >/dev/null || { echo "cmake is required to build flatc"; exit 1; }
command -v make  >/dev/null || { echo "make is required to build flatc";  exit 1; }

CONCURRENCY="${ASDF_CONCURRENCY:-$( (nproc 2>/dev/null) || (sysctl -n hw.ncpu 2>/dev/null) || echo 4 )}"

BUILD_DIR="$(mktemp -d)"
trap 'rm -rf "$BUILD_DIR"' EXIT

cp -R "$ASDF_DOWNLOAD_PATH/." "$BUILD_DIR/"
cd "$BUILD_DIR"

echo "Configuring (cmake) ..."
cmake -G "Unix Makefiles" \
  -DCMAKE_BUILD_TYPE=Release \
  -DCMAKE_INSTALL_PREFIX="$ASDF_INSTALL_PATH" \
  -DFLATBUFFERS_BUILD_TESTS=OFF \
  .

echo "Building with -j${CONCURRENCY} ..."
make -j"${CONCURRENCY}"

echo "Installing into ${ASDF_INSTALL_PATH} ..."
make install   # installs flatc into $ASDF_INSTALL_PATH/bin

# Sanity check: asdf expects the binary under $ASDF_INSTALL_PATH/bin.
test -x "$ASDF_INSTALL_PATH/bin/flatc" \
  || { echo "flatc not found after install"; exit 1; }

echo "flatc ${ASDF_INSTALL_VERSION} installed."
