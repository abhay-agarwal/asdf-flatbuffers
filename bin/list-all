#!/usr/bin/env bash
set -euo pipefail

REPO="https://github.com/google/flatbuffers.git"

# List remote tags, keep only vYY.MM.DD-style date versions, strip the leading "v".
git ls-remote --tags --refs "$REPO" \
  | awk -F/ '{print $NF}' \
  | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' \
  | sed 's/^v//' \
  | sort -t. -k1,1n -k2,2n -k3,3n \
  | tr '\n' ' '
